generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model AppSettings {
  id        String   @id @default("singleton")
  data      String
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("operador")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  documento String?
  budgets   Budget[]
}

model Material {
  id          String    @id @default(cuid())
  nome        String
  marca       String?
  tipo        String?
  linha       String?
  cor         String?
  precoKg     Float
  precoCompra Float?
  estoqueG    Float     @default(0)
  dataCompra  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Machine {
  id             String    @id @default(cuid())
  name           String
  tipo           String    @default("3D")
  marca          String    @default("N/A")
  modelo         String    @default("Padrão")
  numeroSerie    String    @default("N/A")
  dataAquisicao  DateTime?
  precoAquisicao Float?
  vidaUtilH      Float     @default(2000)
  valorResidual  Float     @default(0)
  custoMaquinaH  Float
  custoEnergiaH  Float
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  budgets        Budget[]
}

model Budget {
  id             String   @id @default(cuid())
  nomePeca       String
  clientId       String
  nomeMaterial   String
  pesoG          Float
  tempoH         Int
  tempoM         Int
  tipoServico    String   @default("3D")
  custoMaterial  Float
  custoEnergia     Float
  custoMaquina     Float
  custoDepreciacao Float   @default(0)
  custoTotal       Float
  margemPercent  Float
  impostoPercent Float
  setupCost      Float    @default(0)
  finishingCost  Float    @default(0)
  urgencyCost    Float    @default(0)
  shippingCost   Float    @default(0)
  precoFinal     Float
  lucro          Float
  prazoEntrega   String?
  observacao     String?
  pdfBase64      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cliente        Client   @relation(fields: [clientId], references: [id])
  machineId      String?
  machine        Machine? @relation(fields: [machineId], references: [id])
  status           String   @default("PENDENTE")
  budgetNumber     String?  @unique
  orderNumber      String?  @unique
  formaPagamento   String?
  condicoesComerciais String?
  corPeca          String?
}
